{
  "name": "snazzy-sprocket/theme",
  "description": "Snazzy Sprocket agency WordPress theme built with Timber and Tailwind CSS",
  "type": "wordpress-theme",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=8.1",
    "timber/timber": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "SnazzySprocket\\": "src/"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true,
    "allow-plugins": {
      "composer/installers": true
    }
  }
}
