{#
   views/partials/team-member-card.twig
   -------------------------------------
   Expects:
     - member : Timber\Post of type `team_member`.

   Placeholder: when a member has no thumbnail we render a solid tile
   with their initials on top. The swatch is picked deterministically
   from the member ID so the grid keeps a stable palette between loads
   (teal, navy, slate, cyan, accent-dim — all from tailwind.config.js).
#}

{% set _initials = member.title
    |split(' ')
    |slice(0, 2)
    |map(part => part|first|upper)
    |join %}

{% set _swatches = [
    { bg: 'bg-accent',      fg: 'text-ink'   },
    { bg: 'bg-brand-navy',  fg: 'text-white' },
    { bg: 'bg-slate',       fg: 'text-white' },
    { bg: 'bg-brand-teal',  fg: 'text-white' },
    { bg: 'bg-accent-dim',  fg: 'text-white' }
] %}
{% set _swatch = _swatches[member.id % _swatches|length] %}

<div class="group text-center">
    <div class="relative mb-md overflow-hidden aspect-square bg-fog">
        {% if member.thumbnail %}
            <img
                src="{{ member.thumbnail.src('team-headshot') }}"
                alt="{{ member.title }}"
                class="w-full h-full object-cover grayscale group-hover:grayscale-0 group-hover:scale-[1.03] transition-all duration-500"
                loading="lazy"
            >
        {% else %}
            <div class="w-full h-full flex items-center justify-center {{ _swatch.bg }} {{ _swatch.fg }}"
                 aria-hidden="true">
                <span class="font-display font-extrabold text-2xl md:text-3xl tracking-tight">
                    {{ _initials }}
                </span>
            </div>
        {% endif %}

        {% if member.meta('linkedin_url') or member.meta('twitter_url') %}
        <div class="absolute inset-0 bg-ink/85 flex items-center justify-center gap-sm opacity-0 group-hover:opacity-100 transition-opacity duration-300">
            {% if member.meta('linkedin_url') %}
                <a href="{{ member.meta('linkedin_url') }}" target="_blank" rel="noopener"
                   class="w-9 h-9 bg-white/10 hover:bg-accent hover:text-ink flex items-center justify-center text-white transition-colors no-underline"
                   aria-label="LinkedIn profile for {{ member.title }}">
                    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                </a>
            {% endif %}
            {% if member.meta('twitter_url') %}
                <a href="{{ member.meta('twitter_url') }}" target="_blank" rel="noopener"
                   class="w-9 h-9 bg-white/10 hover:bg-accent hover:text-ink flex items-center justify-center text-white transition-colors no-underline"
                   aria-label="Twitter profile for {{ member.title }}">
                    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                </a>
            {% endif %}
        </div>
        {% endif %}
    </div>

    <h3 class="font-display font-extrabold text-body text-ink">{{ member.title }}</h3>
    <p class="mt-1 text-label uppercase tracking-[0.14em] text-accent-dim">
        {{ member.meta('job_title')|default('Team Member') }}
    </p>

    {% if member.meta('short_bio') %}
        <p class="mt-sm text-small text-ink-mid leading-relaxed max-w-[200px] mx-auto">
            {{ member.meta('short_bio')|raw }}
        </p>
    {% endif %}
</div>
