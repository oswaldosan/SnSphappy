{% extends "base.twig" %}

{% block meta_description %}{{ archive_description }}{% endblock %}

{% block content %}

    {# ============================================
       ARCHIVE HERO
       ============================================ #}
    {% include 'components/page-hero.twig' with {
        eyebrow: archive_eyebrow,
        heading: archive_title,
        lede:    archive_description
    } only %}

    {# ============================================
       FILTERS + CASE STUDY GRID
       ============================================ #}
    <section class="section section-muted" x-data="caseStudyFilters">
        <div class="container-snz">

            <div class="mb-xl space-y-lg">
                {# Industry filters #}
                {% if industries|length > 0 %}
                <div>
                    <p class="form-label mb-sm">Filter by Industry</p>
                    <div class="flex flex-wrap gap-sm">
                        <button type="button" class="chip" :class="activeIndustry === 'all' ? 'is-active' : ''" @click="setIndustry('all')">
                            All Industries
                        </button>
                        {% for industry in industries %}
                            <button type="button"
                                    class="chip"
                                    :class="activeIndustry === '{{ industry.slug }}' ? 'is-active' : ''"
                                    @click="setIndustry('{{ industry.slug }}')">
                                {{ industry.name }}
                            </button>
                        {% endfor %}
                    </div>
                </div>
                {% endif %}

                {# Technology filters #}
                {% if technologies|length > 0 %}
                <div>
                    <p class="form-label mb-sm">Filter by Technology</p>
                    <div class="flex flex-wrap gap-sm">
                        <button type="button" class="chip" :class="activeTechnology === 'all' ? 'is-active' : ''" @click="setTechnology('all')">
                            All Technologies
                        </button>
                        {% for tech in technologies %}
                            <button type="button"
                                    class="chip"
                                    :class="activeTechnology === '{{ tech.slug }}' ? 'is-active' : ''"
                                    @click="setTechnology('{{ tech.slug }}')">
                                {{ tech.name }}
                            </button>
                        {% endfor %}
                    </div>
                </div>
                {% endif %}
            </div>

            {# Case Studies Grid — Figma "Work cards: 3 columns, 24px gap" #}
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-lg">
                {% for study in case_studies %}
                    {% set industry_slugs = [] %}
                    {% for term in study.terms('industry') %}
                        {% set industry_slugs = industry_slugs|merge([term.slug]) %}
                    {% endfor %}

                    {% set tech_slugs = [] %}
                    {% for term in study.terms('technology') %}
                        {% set tech_slugs = tech_slugs|merge([term.slug]) %}
                    {% endfor %}

                    {# Use SINGLE quotes for the attribute so `json_encode`'s
                       double-quoted JSON (e.g. `["healthcare"]`) doesn't
                       prematurely close the attribute in the browser. #}
                    <div
                        x-show='isVisible({{ industry_slugs|json_encode }}, {{ tech_slugs|json_encode }})'
                        x-transition:enter="transition ease-out duration-300"
                        x-transition:enter-start="opacity-0 scale-95"
                        x-transition:enter-end="opacity-100 scale-100"
                        x-transition:leave="transition ease-in duration-200"
                        x-transition:leave-start="opacity-100 scale-100"
                        x-transition:leave-end="opacity-0 scale-95"
                    >
                        {% include 'partials/case-study-card.twig' with { study: study } %}
                    </div>
                {% endfor %}
            </div>

            {# Empty state #}
            <div class="text-center py-2xl" x-show="visibleCount() === 0" x-cloak>
                <h3 class="text-ink mb-sm">No case studies match your filters</h3>
                <p class="text-small text-muted">Try a different combination of industry and technology.</p>
                <div class="mt-md inline-flex">
                    {% include 'components/button.twig' with {
                        label:   'Clear All Filters',
                        as:      'button',
                        variant: 'outline',
                        arrow:   false,
                        attrs:   { '@click': "setIndustry('all'); setTechnology('all')" }
                    } only %}
                </div>
            </div>
        </div>
    </section>

{% endblock %}
