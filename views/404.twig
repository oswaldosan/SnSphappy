{% extends "base.twig" %}

{% block content %}
    <section class="relative bg-hero-dot text-white -mt-20 pt-20 overflow-hidden">
        <div class="container-snz pt-lg md:pt-xl lg:pt-2xl pb-2xl md:pb-3xl lg:pb-4xl text-center relative">
            <p class="font-display font-extrabold text-[6.5rem] sm:text-[9rem] md:text-[14rem] leading-none text-gradient-accent mb-md">
                404
            </p>
            <h1 class="text-white mb-md">Page not found</h1>
            <p class="lede max-w-md mx-auto mb-xl">
                Sorry, we couldn't find what you're looking for. It may have been moved or no longer exists.
            </p>
            {% include 'components/button.twig' with {
                label:   'Back to Homepage',
                href:    site.url,
                variant: 'primary'
            } only %}
        </div>
    </section>
{% endblock %}
