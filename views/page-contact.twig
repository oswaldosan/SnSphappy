{% extends "base.twig" %}

{% block meta_description %}Get in touch with Snazzy Sprocket. We'd love to hear about your project.{% endblock %}

{% block content %}

    {# ============================================
       CONTACT HERO
       ============================================ #}
    {% include 'components/page-hero.twig' with {
        eyebrow:      'Contact us',
        heading_html: post.meta('contact_headline')|default('Let\'s start something <em>great</em>.'),
        lede:         post.meta('contact_subheadline')|default("Whether you have a project in mind or just want to say hello, we'd love to hear from you.")
    } only %}

    {# ============================================
       FORM + INFO
       ============================================ #}
    <section class="section bg-white">
        <div class="container-snz">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-xl lg:gap-2xl">

                {# ---- Contact form ---- #}
                <div class="lg:col-span-7">
                    <p class="eyebrow mb-sm">Project brief</p>
                    <h2 class="mb-lg">Send us a message</h2>

                    <div class="contact-form-wrapper
                                [&_.wpcf7-form]:space-y-md
                                [&_input:not([type=submit])]:form-input
                                [&_textarea]:form-textarea
                                [&_select]:form-select
                                [&_.wpcf7-submit]:btn-primary [&_.wpcf7-submit]:w-full [&_.wpcf7-submit]:sm:w-auto
                                [&_.wpcf7-response-output]:mt-md [&_.wpcf7-response-output]:p-md [&_.wpcf7-response-output]:text-small [&_.wpcf7-response-output]:border [&_.wpcf7-response-output]:border-fog
                                [&_.wpcf7-not-valid-tip]:text-red-600 [&_.wpcf7-not-valid-tip]:text-small [&_.wpcf7-not-valid-tip]:mt-1
                                [&_label]:form-label">
                        {{ contact_form|raw }}
                    </div>
                </div>

                {# ---- Info sidebar — dark notch card ---- #}
                <aside class="lg:col-span-5">
                    <div class="card card-dark card-notch p-lg md:p-xl space-y-lg">

                        <div>
                            <p class="eyebrow mb-sm">Direct line</p>
                            <h3 class="text-white mb-sm">Get in touch</h3>
                            <p class="text-cloud text-small leading-relaxed">
                                Prefer a direct conversation? Reach out through any of the channels below.
                            </p>
                        </div>

                        {# Email #}
                        <div class="flex gap-md">
                            <span class="notch-xs w-10 h-10 bg-accent/20 text-accent flex items-center justify-center flex-shrink-0">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
                            </span>
                            <div>
                                <p class="form-label text-cloud">Email</p>
                                <a href="mailto:{{ options.email|default('hello@snazzysprocket.dev') }}" class="text-body text-white hover:text-accent transition-colors no-underline">
                                    {{ options.email|default('hello@snazzysprocket.dev') }}
                                </a>
                            </div>
                        </div>

                        {# Phone #}
                        <div class="flex gap-md">
                            <span class="notch-xs w-10 h-10 bg-accent/20 text-accent flex items-center justify-center flex-shrink-0">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
                            </span>
                            <div>
                                <p class="form-label text-cloud">Phone</p>
                                <a href="tel:{{ options.phone|default('+15551234567') }}" class="text-body text-white hover:text-accent transition-colors no-underline">
                                    {{ options.phone|default('+1 (555) 123-4567') }}
                                </a>
                            </div>
                        </div>

                        {# Address #}
                        <div class="flex gap-md">
                            <span class="notch-xs w-10 h-10 bg-accent/20 text-accent flex items-center justify-center flex-shrink-0">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
                            </span>
                            <div>
                                <p class="form-label text-cloud">Office</p>
                                <p class="text-body text-white leading-relaxed">
                                    {{ options.address|default('123 Innovation Drive, Suite 400, San Francisco, CA 94107') }}
                                </p>
                            </div>
                        </div>

                        <div class="pt-md border-t border-white/10">
                            <p class="form-label text-cloud mb-sm">Follow Us</p>
                            <div class="flex gap-sm">
                                {% set social_items = [
                                    { name: 'Twitter',  url: options.social_twitter|default('#') },
                                    { name: 'LinkedIn', url: options.social_linkedin|default('#') },
                                    { name: 'GitHub',   url: options.social_github|default('#') },
                                    { name: 'Dribbble', url: options.social_dribbble|default('#') }
                                ] %}
                                {% for item in social_items %}
                                    <a href="{{ item.url }}"
                                       class="notch-xs w-10 h-10 bg-white/5 hover:bg-accent hover:text-ink flex items-center justify-center text-white transition-colors no-underline"
                                       aria-label="{{ item.name }}" target="_blank" rel="noopener noreferrer">
                                        <span class="text-label font-bold">{{ item.name|slice(0, 2) }}</span>
                                    </a>
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                </aside>

            </div>
        </div>
    </section>

    {# ============================================
       MAP — Google Maps embed (keyless).
       Coordinates match the address above; adjust
       by editing the `q=` query param. Loads lazily
       so it never blocks above-the-fold rendering.
       ============================================ #}
    <section class="section-sm bg-white" aria-labelledby="contact-map-heading">
        <div class="container-snz">
            <h2 id="contact-map-heading" class="sr-only">Our location on the map</h2>
            <div class="relative w-full aspect-[16/9] md:aspect-[21/9] bg-paper border border-fog overflow-hidden">
                <iframe
                    src="https://maps.google.com/maps?q=15.5732425,-87.9628829&z=12&output=embed"
                    class="absolute inset-0 w-full h-full"
                    style="border:0"
                    loading="lazy"
                    referrerpolicy="no-referrer-when-downgrade"
                    allowfullscreen
                    title="Snazzy Sprocket location map"
                ></iframe>
            </div>
        </div>
    </section>

{% endblock %}
